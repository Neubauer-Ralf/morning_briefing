# Morning Briefing Printer Configuration
# Copy this file to .env and fill in your values.

# Printer name (find yours with: lpstat -p)
PRINTER_NAME=your-printer-name

# Printer character width (32 for 58mm, 48 for 80mm)
# PRINT_WIDTH=32

# Weather location (default: Gosberg, Germany)
# Find coordinates at https://open-meteo.com
# LATITUDE=49.70
# LONGITUDE=11.02
# LOCATION_NAME=Gosberg

# Calendar URLs (comma-separated for multiple calendars)
# Supports Outlook, Apple iCloud, Google Calendar iCal URLs
ICAL_URLS=https://your-first-calendar.ics,https://your-second-calendar.ics

# Number of news headlines
# NUM_HEADLINES=5

# RSS feed for news (default: BBC World)
# NEWS_RSS_URL=https://feeds.bbci.co.uk/news/world/rss.xml

# Greeting message at the bottom of the receipt
# GREETING=Have a great day!
